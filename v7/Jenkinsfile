pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                bat 'cd v7 && docker compose build --no-cache'
            }
        }
        stage('Arret') {
            steps {
                bat 'cd v7 && docker compose down --remove-orphans || exit 0'
                bat 'docker rm -f portfolio_mongo portfolio_backend portfolio_frontend || exit 0'
            }
        }
        stage('Deploiement') {
            steps {
                bat 'cd v7 && docker compose up -d'
                bat 'ping -n 16 127.0.0.1 > nul'
            }
        }
        stage('Verification') {
            steps {
                bat 'cd v7 && docker compose ps'
            }
        }
    }
    post {
        success {
            echo 'DEPLOIEMENT REUSSI - http://localhost:8080'
        }
        failure {
            echo 'Pipeline echoue'
        }
        always {
            bat 'cd v7 && docker compose ps || exit 0'
        }
    }
}