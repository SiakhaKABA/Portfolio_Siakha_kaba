// Pipeline operationnel
pipeline {
    agent any

    environment {
        COMPOSE_FILE = 'docker-compose.deploy.yml'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Preparation env') {
            steps {
                bat 'copy "C:\\secrets\\backend.env" "%WORKSPACE%\\v7\\backend\\.env"'
            }
        }

        stage('Build') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% build --no-cache"
            }
        }

        stage('Arret') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% down --remove-orphans || exit 0"
            }
        }

        stage('Deploiement') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% up -d"
                sleep(time: 15, unit: 'SECONDS')
            }
        }

        stage('Verification') {
            steps {
                bat "cd v7 && docker compose -f %COMPOSE_FILE% ps"
                bat "cd v7 && docker compose -f %COMPOSE_FILE% logs --tail=30 frontend"
                bat "cd v7 && docker compose -f %COMPOSE_FILE% logs --tail=30 backend"
            }
        }

    }

    post {

        success {
            echo "Pipeline reussi - Portfolio deploye"
            emailext(
                subject: "SUCCESS - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "<h2>Deploiement reussi</h2><p><b>Projet :</b> ${env.JOB_NAME}</p><p><b>Build :</b> ${env.BUILD_NUMBER}</p><p><b>Statut :</b> SUCCESS</p><p><b>Lien :</b> <a href='${env.BUILD_URL}'>${env.BUILD_URL}</a></p><p>Le portfolio a ete deploye avec succes sur <a href='http://localhost:8080'>http://localhost:8080</a>.</p>",
                mimeType: 'text/html',
                to: 'siakha.kaba@gmail.com'
            )
        }

        failure {
            echo "Pipeline echoue - consulte les logs"
            bat "cd v7 && docker compose -f %COMPOSE_FILE% logs --tail=100 || exit 0"
            bat "cd v7 && docker compose -f %COMPOSE_FILE% down || exit 0"
            emailext(
                subject: "FAILURE - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: "<h2>Deploiement echoue</h2><p><b>Projet :</b> ${env.JOB_NAME}</p><p><b>Build :</b> ${env.BUILD_NUMBER}</p><p><b>Statut :</b> FAILURE</p><p><b>Logs :</b> <a href='${env.BUILD_URL}'>${env.BUILD_URL}</a></p><p>Une erreur est survenue pendant le pipeline.</p>",
                mimeType: 'text/html',
                to: 'siakha.kaba@gmail.com'
            )
        }

        always {
            echo "Verification finale (workspace conserve pour les bind-mounts)"
            bat "cd v7 && docker compose -f %COMPOSE_FILE% ps || exit 0"
            // PAS de cleanWs() : si on supprime le workspace, les containers perdent leur code
        }

    }
}
