pipeline {
    agent any

    environment {
        APP_NAME     = 'portfolio'
        FRONTEND_URL = 'http://localhost:8080'
        BACKEND_URL  = 'http://localhost:3001'
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Recuperation du code depuis GitHub...'
                checkout scm
            }
        }

        stage('Verification') {
            steps {
                echo 'Verification de l environnement...'
                bat 'docker --version'
                bat 'docker compose version'
                bat 'dir'
            }
        }

        stage('Build') {
            steps {
                echo 'Build des images Docker...'
                bat 'docker compose build --no-cache'
            }
        }

        stage('Arret ancienne version') {
            steps {
                echo 'Arret des anciens conteneurs...'
                bat 'docker compose down --remove-orphans || exit 0'
            }
        }

        stage('Deploiement') {
            steps {
                echo 'Demarrage des conteneurs...'
                bat 'docker compose up -d'
                echo 'Attente du demarrage (15 sec)...'
                bat 'timeout /t 15 /nobreak'
            }
        }

        stage('Verification sante') {
            steps {
                echo 'Verification que les services sont UP...'
                bat 'docker compose ps'
            }
        }
    }

    post {
        success {
            echo 'DEPLOIEMENT REUSSI — http://localhost:8080'
        }
        failure {
            echo 'Pipeline echoue — rollback...'
            bat 'docker compose down || exit 0'
        }
        always {
            echo 'Fin du pipeline'
            bat 'docker compose ps || exit 0'
        }
    }
}
